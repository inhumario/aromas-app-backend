# Backend de la app Aromas de Té — variables de entorno

# Conexión a Postgres (usar la interna de easypanel si el backend corre ahí mismo)
DATABASE_URL=postgres://usuario:password@host:5432/basededatos

# 'disable' si la conexión interna no usa SSL; cualquier otro valor activa SSL
PGSSLMODE=disable

# Puerto en el que escucha el servicio
PORT=3000

# Endpoint GraphQL de la Customer Account API de Shopify (para validar el token del cliente)
SHOPIFY_CUSTOMER_API=https://shopify.com/79280144711/account/customer/api/2025-01/graphql

# Trusted Shops / eTrusted — valoraciones de producto
TS_CLIENT_ID=
TS_CLIENT_SECRET=
TS_OAUTH_URL=https://login.etrusted.com/oauth/token
TS_AUDIENCE=https://api.etrusted.com
TS_API_BASE=https://api.etrusted.com

# Panel de envío de notificaciones (/admin) — usuario y contraseña de acceso
ADMIN_USER=aromas
ADMIN_PASSWORD=

# Secreto de firma de los webhooks de Shopify (Ajustes → Notificaciones → Webhooks)
# Necesario para los avisos automáticos del estado del pedido.
SHOPIFY_WEBHOOK_SECRET=

# URL pública del backend. Solo hace falta cambiarla si el dominio cambia;
# se usa para construir el enlace de la imagen del popup del inicio.
PUBLIC_BASE_URL=https://app-api.aromasdete.com
