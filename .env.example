# Backend de la app Aromas de Té — variables de entorno

# Conexión a Postgres (usar la interna de easypanel si el backend corre ahí mismo)
DATABASE_URL=postgres://usuario:password@host:5432/basededatos

# 'disable' si la conexión interna no usa SSL; cualquier otro valor activa SSL
PGSSLMODE=disable

# Puerto en el que escucha el servicio
PORT=3000

# Endpoint GraphQL de la Customer Account API de Shopify (para validar el token del cliente)
SHOPIFY_CUSTOMER_API=https://shopify.com/79280144711/account/customer/api/2025-01/graphql

# Trusted Shops / eTrusted — valoraciones de producto
TS_CLIENT_ID=
TS_CLIENT_SECRET=
TS_OAUTH_URL=https://login.etrusted.com/oauth/token
TS_AUDIENCE=https://api.etrusted.com
TS_API_BASE=https://api.etrusted.com

# Panel de administración (/admin). El panel ahora gestiona varios usuarios
# con cookie de sesión firmada: estas dos variables solo se usan la PRIMERA
# vez que arranca para crear el usuario admin inicial. Después, se gestionan
# las altas/bajas/contraseñas desde el propio panel.
ADMIN_USER=aromas
ADMIN_PASSWORD=

# Secreto para firmar las cookies de sesión del panel. Si se deja vacío, el
# servidor genera uno aleatorio al arrancar, lo que invalida sesiones tras
# cada redeploy. Para evitarlo, define un valor estable (32 bytes hex).
#   openssl rand -hex 32
SESSION_SECRET=

# Secreto de firma de los webhooks de Shopify (Ajustes → Notificaciones → Webhooks)
# Necesario para los avisos automáticos del estado del pedido.
SHOPIFY_WEBHOOK_SECRET=

# Admin API de Shopify (lectura de pedidos para el stat "Pedidos en la app").
# Token de la app personalizada "Claude" en Aromas — scope read_orders.
SHOPIFY_STORE_DOMAIN=aromasdete.myshopify.com
SHOPIFY_ADMIN_TOKEN=
SHOPIFY_ADMIN_API_VERSION=2025-01
# Prefijo del source_name del canal de la app móvil en Shopify (el channel ID
# que Shopify asigna a los pedidos hechos desde la app). Por defecto el de
# Aromas; si Shopify cambia el ID, ajustar aquí.
SHOPIFY_APP_SOURCE_PREFIX=269681

# URL pública del backend. Solo hace falta cambiarla si el dominio cambia;
# se usa para construir el enlace de la imagen del popup del inicio.
PUBLIC_BASE_URL=https://app-api.aromasdete.com
